<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.wini.winitest.mapper.UserMapper">

    <resultMap id="userResultMap" type="com.wini.winitest.vo.UserVO">
        <id     property="userId"   column="user_id"/>
        <result property="userPw"   column="user_pw"/>
        <result property="userName" column="user_name"/>
        <result property="regDate"  column="reg_date"/>
    </resultMap>

    <!-- 로그인 -->
    <select id="login" parameterType="com.wini.winitest.vo.UserVO" resultMap="userResultMap">
        SELECT *
        FROM users
        WHERE user_id = #{userId}
        AND user_pw = #{userPw}
    </select>

    <!-- 아이디 중복확인 -->
    <select id="idCheck" parameterType="String" resultType="int">
        SELECT COUNT(*)
        FROM users
        WHERE user_id = #{userId}
    </select>

    <!-- 회원가입 -->
    <insert id="register" parameterType="com.wini.winitest.vo.UserVO">
        INSERT INTO users (user_id, user_pw, user_name, reg_date)
        VALUES (#{userId}, #{userPw}, #{userName}, NOW())
    </insert>

</mapper>